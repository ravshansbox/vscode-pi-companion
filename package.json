{
  "name": "vscode-pi-companion",
  "displayName": "VS Code",
  "description": "Share VS Code context with pi coding agent",
  "repository": "https://github.com/ravshansbox/vscode-pi-companion",
  "version": "0.1.6",
  "publisher": "ravshansbox",
  "keywords": [
    "pi-package"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "VS Code",
      "properties": {
        "piCompanion.port": {
          "type": "number",
          "default": 8765,
          "description": "Port for MCP server"
        }
      }
    },
    "commands": [
      {
        "command": "pi-companion.start",
        "title": "VS Code: Start Server"
      },
      {
        "command": "pi-companion.stop",
        "title": "VS Code: Stop Server"
      },
      {
        "command": "pi-companion.status",
        "title": "VS Code: Show Status"
      }
    ]
  }
}
